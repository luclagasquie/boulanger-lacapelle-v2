---
import BaseLayout from "../layouts/BaseLayout.astro";
import { bakery, adminCookieName } from "../lib/config";
import { clearAdminCookie, isAdminAuthenticated, isAdminConfigured } from "../lib/admin";
import {
  formatCurrency,
  isDatabaseConfigured,
  listAllProducts,
  listOrderDates,
  listOrdersForPickupDate,
  priceFromWeight
} from "../lib/db";

const secure = Astro.url.protocol === "https:";
const searchParams = Astro.url.searchParams;
const adminCookie = Astro.cookies.get(adminCookieName)?.value;
const isAuthenticated = isAdminAuthenticated(adminCookie);
const configured = isAdminConfigured();
const databaseConfigured = isDatabaseConfigured();

if (searchParams.get("logout") === "1") {
  clearAdminCookie(Astro.cookies, secure);
}

const status = searchParams.get("status");
const selectedPickupDate = searchParams.get("pickup");

const products = isAuthenticated ? await listAllProducts() : [];
const orderDates = isAuthenticated ? await listOrderDates() : [];
const currentPickup = selectedPickupDate || orderDates[0]?.pickup_date || "";
const orders = isAuthenticated && currentPickup ? await listOrdersForPickupDate(currentPickup) : [];
const totals = orders.reduce(
  (acc, order) => {
    acc.orders += 1;
    acc.items += order.items.reduce((sum, item) => sum + item.quantity, 0);
    acc.turnover += order.total_cents;
    return acc;
  },
  { orders: 0, items: 0, turnover: 0 }
);

const messageMap: Record<string, { type: "success" | "error"; message: string }> = {
  auth: {
    type: "error",
    message: "Mot de passe incorrect."
  },
  product_saved: {
    type: "success",
    message: "Produit enregistré."
  },
  product_deleted: {
    type: "success",
    message: "Produit supprimé."
  },
  orders_reset: {
    type: "success",
    message: "Le tableau de commande a été réinitialisé pour cette date."
  },
  storage: {
    type: "error",
    message: "Le binding D1 `DB` n'est pas configuré sur Cloudflare."
  },
  invalid: {
    type: "error",
    message: "Les données envoyées sont invalides."
  },
  server_error: {
    type: "error",
    message: "Une erreur serveur est survenue pendant la connexion. Vérifiez les logs Cloudflare."
  }
};

const flash = status ? messageMap[status] : null;
const defaultProductImage = "/images/pain-au-levain.svg";
---

<BaseLayout title="Espace boulanger | Zacharie Zion" description="Gestion des commandes et des produits de la boulangerie.">
  <main class="page page--admin">
    <section class="hero hero--compact">
      <div class="hero__copy">
        <p class="eyebrow">Administration</p>
        <h1>Espace boulanger de {bakery.bakerName}</h1>
        <p class="hero__lead">
          Consultation des réservations, mise à jour du catalogue et réinitialisation du tableau de commande.
        </p>
      </div>
    </section>

    {!configured && (
      <p class="flash flash--error">
        Configurez d'abord `ADMIN_PASSWORD` et `ADMIN_SESSION_TOKEN` dans les secrets Cloudflare ou dans `.dev.vars`.
      </p>
    )}
    {!databaseConfigured && (
      <p class="flash flash--error">
        Configurez aussi le binding D1 `DB` sur Cloudflare. Sans lui, le tableau de bord et l'enregistrement des commandes restent
        indisponibles.
      </p>
    )}

    {flash && <p class={`flash flash--${flash.type}`}>{flash.message}</p>}

    {!isAuthenticated ? (
      <section class="admin-login">
        <form method="POST" action="/api/admin/login" class="auth-card">
          <p class="section-heading__eyebrow">Connexion protégée</p>
          <h2>Acces Zacharie</h2>
          <label>
            <span>Mot de passe</span>
            <input type="password" name="password" required />
          </label>
          <button class="cta" type="submit" disabled={!configured}>
            Ouvrir le tableau de bord
          </button>
        </form>
      </section>
    ) : !databaseConfigured ? (
      <section class="admin-login">
        <div class="auth-card">
          <p class="section-heading__eyebrow">Configuration Cloudflare</p>
          <h2>Binding D1 requis</h2>
          <p>
            Le site est déployé sans le binding `DB`. Ajoutez la base D1 sur le projet Cloudflare cible, puis redéployez pour
            retrouver le tableau de bord complet.
          </p>
        </div>
      </section>
    ) : (
      <>
        <section class="admin-toolbar">
          <div class="stats-grid">
            <article class="stat-card">
              <span>Commandes</span>
              <strong>{totals.orders}</strong>
            </article>
            <article class="stat-card">
              <span>Pains reserves</span>
              <strong>{totals.items}</strong>
            </article>
            <article class="stat-card">
              <span>Total journee</span>
              <strong>{formatCurrency(totals.turnover)}</strong>
            </article>
          </div>
          <form method="POST" action="/api/admin/logout">
            <button class="secondary-button" type="submit">Se déconnecter</button>
          </form>
        </section>

        <section class="admin-grid">
          <div class="admin-column">
            <section class="admin-card">
              <div class="section-heading">
                <div>
                  <p class="section-heading__eyebrow">Commandes</p>
                  <h2>Tableau de journee</h2>
                </div>
              </div>

              <form class="pickup-filter" method="GET" action="/admin">
                <label>
                  <span>Date de retrait</span>
                  <select name="pickup" onchange="this.form.submit()">
                    {orderDates.length === 0 && <option value="">Aucune reservation</option>}
                    {orderDates.map((date) => (
                      <option value={date.pickup_date} selected={date.pickup_date === currentPickup}>
                        {date.pickup_label} - {date.order_count} commande(s)
                      </option>
                    ))}
                  </select>
                </label>
              </form>

              {currentPickup && orderDates.length > 0 ? (
                <>
                  <div class="admin-day-actions">
                    <a class="secondary-button" href={`/api/admin/orders/export?pickup=${encodeURIComponent(currentPickup)}`}>
                      Télécharger en CSV
                    </a>
                  </div>

                  <div class="orders-list">
                    {orders.map((order) => (
                      <article class="order-card">
                        <div class="order-card__header">
                          <div>
                            <h3>
                              {order.customer_first_name} {order.customer_last_name}
                            </h3>
                            <p>{order.phone}</p>
                          </div>
                          <strong>{formatCurrency(order.total_cents)}</strong>
                        </div>
                        <ul class="plain-list">
                          {order.items.map((item) => (
                            <li>
                              {item.quantity} x {item.product_title} ({item.weight_grams} g) - {formatCurrency(item.line_total_cents)}
                            </li>
                          ))}
                        </ul>
                      </article>
                    ))}
                  </div>

                  <div class="admin-day-actions">
                    <form method="POST" action="/api/admin/orders/reset" onsubmit="return confirm('Supprimer toutes les commandes de cette date ?');">
                      <input type="hidden" name="pickupDate" value={currentPickup} />
                      <button class="danger-button" type="submit">Réinitialiser cette journée</button>
                    </form>
                  </div>
                </>
              ) : (
                <p class="empty-state">Aucune commande pour le moment.</p>
              )}
            </section>
          </div>

          <div class="admin-column">
            <section class="admin-card">
              <div class="section-heading">
                <div>
                  <p class="section-heading__eyebrow">Catalogue</p>
                  <h2>Ajouter un produit</h2>
                </div>
              </div>

              <div class="product-editor product-editor--create" data-product-editor>
                <div class="product-preview">
                  <img src={defaultProductImage} alt="Apercu du nouveau produit" data-image-preview />
                </div>

                <form class="product-form product-form--create" method="POST" action="/api/admin/products/create" data-product-form>
                  <label class="product-form__wide">
                    <span>Titre</span>
                    <input type="text" name="title" required maxlength="80" />
                  </label>
                  <label>
                    <span>Slug</span>
                    <input type="text" name="slug" placeholder="laisser vide pour auto" maxlength="80" />
                  </label>
                  <label>
                    <span>Poids (g)</span>
                    <input type="number" name="weightGrams" min="50" max="5000" required />
                  </label>
                  <label>
                    <span>Prix au kilo (EUR)</span>
                    <input type="number" name="pricePerKg" min="0.1" max="100" step="0.01" required />
                  </label>
                  <label>
                    <span>Image</span>
                    <input type="text" name="imageUrl" value={defaultProductImage} required data-image-input />
                  </label>
                  <p class="product-form__hint product-form__wide">
                    Le produit est ajouté en fin de liste. Vous pourrez ensuite le repositionner par glisser-déposer.
                  </p>
                  <label class="checkbox-row product-form__wide">
                    <input type="checkbox" name="isActive" checked />
                    <span>Produit visible</span>
                  </label>
                  <div class="product-form__actions product-form__wide">
                    <button class="cta" type="submit">Ajouter le produit</button>
                  </div>
                </form>
              </div>
            </section>

            <section class="admin-card">
              <div class="section-heading section-heading--catalog">
                <div>
                  <p class="section-heading__eyebrow">Catalogue</p>
                  <h2>Modifier les produits</h2>
                  <p class="section-heading__note">Glissez chaque carte par sa poignee pour changer l'ordre d'affichage.</p>
                </div>
                <p class="admin-sort-status" data-sort-status aria-live="polite"></p>
              </div>

              <div class="product-admin-list" data-product-sortable data-reorder-endpoint="/api/admin/products/reorder">
                {products.length === 0 ? (
                  <p class="empty-state">Aucun produit pour le moment.</p>
                ) : (
                  products.map((product) => (
                    <article class="product-admin-card" data-product-card data-product-id={product.id}>
                      <div class="product-admin-card__toolbar">
                        <button
                          class="drag-handle"
                          type="button"
                          draggable="true"
                          data-drag-handle
                          aria-label={`Déplacer ${product.title}`}
                          title="Glisser pour changer l'ordre"
                        >
                          <span class="drag-handle__grip" aria-hidden="true">::</span>
                          <span>Déplacer</span>
                        </button>
                        <span class="product-admin-card__position" data-product-position>Position {product.sort_order}</span>
                      </div>

                      <div class="product-editor" data-product-editor>
                        <div class="product-preview">
                          <img src={product.image_url} alt={product.title} loading="lazy" data-image-preview />
                        </div>

                        <div class="product-editor__body">
                          <form class="product-form" method="POST" action="/api/admin/products/update" data-product-form>
                            <input type="hidden" name="id" value={product.id} />
                            <input type="hidden" name="sortOrder" value={product.sort_order} data-sort-order-input />
                            <label class="product-form__wide">
                              <span>Titre</span>
                              <input type="text" name="title" value={product.title} required />
                            </label>
                            <label>
                              <span>Slug</span>
                              <input type="text" name="slug" value={product.slug} required />
                            </label>
                            <label>
                              <span>Poids (g)</span>
                              <input type="number" name="weightGrams" min="50" max="5000" value={product.weight_grams} required />
                            </label>
                            <label>
                              <span>Prix au kilo (EUR)</span>
                              <input
                                type="number"
                                name="pricePerKg"
                                min="0.1"
                                max="100"
                                step="0.01"
                                value={(product.price_per_kg_cents / 100).toFixed(2)}
                                required
                              />
                            </label>
                            <label class="product-form__wide">
                              <span>Image</span>
                              <input type="text" name="imageUrl" value={product.image_url} required data-image-input />
                            </label>
                            <label class="checkbox-row product-form__wide">
                              <input type="checkbox" name="isActive" checked={product.is_active === 1} />
                              <span>Produit visible</span>
                            </label>
                            <div class="product-form__meta product-form__wide">
                              <span>Prix piece estime: {formatCurrency(priceFromWeight(product.weight_grams, product.price_per_kg_cents))}</span>
                            </div>
                            <div class="product-form__actions product-form__wide">
                              <button class="secondary-button" type="submit">Enregistrer</button>
                            </div>
                          </form>

                          <form
                            class="product-delete-form"
                            method="POST"
                            action="/api/admin/products/delete"
                            onsubmit="return confirm('Supprimer ce produit ?');"
                          >
                            <input type="hidden" name="id" value={product.id} />
                            <button class="danger-button" type="submit">Supprimer</button>
                          </form>
                        </div>
                      </div>
                    </article>
                  ))
                )}
              </div>
            </section>
          </div>
        </section>
      </>
    )}
  </main>

  <script is:inline>
    const fallbackProductImage = "/images/pain-au-levain.svg";

    document.querySelectorAll("[data-product-editor]").forEach((editor) => {
      const input = editor.querySelector("[data-image-input]");
      const preview = editor.querySelector("[data-image-preview]");

      if (!(input instanceof HTMLInputElement) || !(preview instanceof HTMLImageElement)) {
        return;
      }

      let lastValidSrc = preview.getAttribute("src") || fallbackProductImage;

      const syncPreview = () => {
        const nextSrc = input.value.trim() || fallbackProductImage;
        preview.src = nextSrc;
      };

      preview.addEventListener("load", () => {
        lastValidSrc = preview.currentSrc || preview.getAttribute("src") || fallbackProductImage;
      });

      preview.addEventListener("error", () => {
        preview.src = lastValidSrc || fallbackProductImage;
      });

      input.addEventListener("input", syncPreview);
      input.addEventListener("change", syncPreview);
      syncPreview();
    });

    const sortableList = document.querySelector("[data-product-sortable]");
    const sortStatus = document.querySelector("[data-sort-status]");

    if (sortableList instanceof HTMLElement) {
      let draggedCard = null;
      let dragStartOrder = "";
      let pendingOrder = null;
      let isSavingOrder = false;

      const getCards = () => Array.from(sortableList.querySelectorAll("[data-product-card]"));

      const getOrderSignature = () =>
        getCards()
          .map((card) => card.getAttribute("data-product-id") || "")
          .join(",");

      const setSortStatus = (message, state = "idle") => {
        if (!(sortStatus instanceof HTMLElement)) {
          return;
        }

        sortStatus.textContent = message;
        sortStatus.dataset.state = state;
      };

      const updateSortMetadata = () => {
        getCards().forEach((card, index) => {
          const sortOrderInput = card.querySelector("[data-sort-order-input]");
          const position = card.querySelector("[data-product-position]");

          if (sortOrderInput instanceof HTMLInputElement) {
            sortOrderInput.value = String(index + 1);
          }

          if (position instanceof HTMLElement) {
            position.textContent = `Position ${index + 1}`;
          }
        });
      };

      const getCardAfterPointer = (pointerY) => {
        return getCards()
          .filter((card) => card !== draggedCard)
          .reduce(
            (closest, card) => {
              const rect = card.getBoundingClientRect();
              const offset = pointerY - rect.top - rect.height / 2;

              if (offset < 0 && offset > closest.offset) {
                return { offset, element: card };
              }

              return closest;
            },
            { offset: Number.NEGATIVE_INFINITY, element: null }
          ).element;
      };

      const persistOrder = async (productIds) => {
        const endpoint = sortableList.dataset.reorderEndpoint;

        if (!endpoint) {
          return;
        }

        const formData = new FormData();
        productIds.forEach((id) => formData.append("productIds[]", id));

        setSortStatus("Enregistrement de l'ordre...", "pending");

        const response = await fetch(endpoint, {
          method: "POST",
          body: formData
        });

        if (!response.ok) {
          throw new Error("save_failed");
        }

        setSortStatus("Ordre enregistré.", "success");
      };

      const flushPendingOrder = async () => {
        if (isSavingOrder || !pendingOrder) {
          return;
        }

        isSavingOrder = true;

        while (pendingOrder) {
          const nextOrder = pendingOrder;
          pendingOrder = null;

          try {
            await persistOrder(nextOrder);
          } catch {
            setSortStatus("Impossible d'enregistrer l'ordre. Rechargez la page et réessayez.", "error");
          }
        }

        isSavingOrder = false;
      };

      sortableList.querySelectorAll("[data-drag-handle]").forEach((handle) => {
        handle.addEventListener("dragstart", (event) => {
          draggedCard = handle.closest("[data-product-card]");

          if (!(draggedCard instanceof HTMLElement)) {
            draggedCard = null;
            return;
          }

          dragStartOrder = getOrderSignature();
          draggedCard.classList.add("is-dragging");

          if (event.dataTransfer) {
            event.dataTransfer.effectAllowed = "move";
            event.dataTransfer.setData("text/plain", draggedCard.dataset.productId || "");
          }

          setSortStatus("Relâchez la carte pour enregistrer le nouvel ordre.", "pending");
        });

        handle.addEventListener("dragend", () => {
          if (!(draggedCard instanceof HTMLElement)) {
            return;
          }

          draggedCard.classList.remove("is-dragging");
          updateSortMetadata();

          const nextOrderSignature = getOrderSignature();

          if (nextOrderSignature && nextOrderSignature !== dragStartOrder) {
            pendingOrder = getCards()
              .map((card) => card.getAttribute("data-product-id") || "")
              .filter(Boolean);
            void flushPendingOrder();
          } else {
            setSortStatus("Glissez une carte par sa poignée pour réordonner le catalogue.");
          }

          draggedCard = null;
        });
      });

      sortableList.addEventListener("dragover", (event) => {
        if (!(draggedCard instanceof HTMLElement)) {
          return;
        }

        event.preventDefault();

        const nextCard = getCardAfterPointer(event.clientY);

        if (!(nextCard instanceof HTMLElement)) {
          sortableList.append(draggedCard);
          return;
        }

        sortableList.insertBefore(draggedCard, nextCard);
      });

      sortableList.addEventListener("drop", (event) => {
        if (draggedCard) {
          event.preventDefault();
        }
      });

      updateSortMetadata();
      setSortStatus("Glissez une carte par sa poignee pour reordonner le catalogue.");
    }
  </script>
</BaseLayout>
